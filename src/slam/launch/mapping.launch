<launch>
  <arg name="database_path"     default="/catkin_ws/src/slam/maps/rtabmap.db"/>
  <arg name="rgb_topic"         default="/camera/rgb/image_raw"/>
  <arg name="depth_topic"       default="/camera/depth/image_raw"/>
  <arg name="camera_info_topic" default="/camera/rgb/camera_info"/>

  <group ns="rtabmap">
    <node name="rtabmap" pkg="rtabmap_slam" type="rtabmap" output="screen" args="--delete_db_on_start">

      <!-- Basic -->
      <param name="database_path"   type="string" value="$(arg database_path)"/>
      <param name="frame_id"        type="string" value="robot_footprint"/>
      <param name="odom_frame_id"   type="string" value="odom"/>
      <param name="subscribe_depth" type="bool"   value="true"/>
      <param name="subscribe_scan"  type="bool"   value="true"/>

      <!-- Inputs -->
      <remap from="scan"            to="/scan"/>
      <remap from="rgb/image"       to="$(arg rgb_topic)"/>
      <remap from="depth/image"     to="$(arg depth_topic)"/>
      <remap from="rgb/camera_info" to="$(arg camera_info_topic)"/>

      <!-- Output -->
      <remap from="grid_map" to="/map"/>

      <!-- 2D SLAM -->
      <param name="Reg/Force3DoF"       type="string" value="true"/>

      <param name="Rtabmap/DetectionRate" type="string" value="2"/>
      <param name="Rtabmap/LoopThr"       type="string" value="0.11"/>
      <param name="Rtabmap/TimeThr"       type="string" value="700"/>

      <param name="Kp/DetectorStrategy"  type="string" value="2"/>
      <param name="Kp/MaxFeatures"       type="string" value="1000"/>
      <param name="Kp/MaxDepth"          type="string" value="4.0"/>
      <param name="Kp/NNStrategy"        type="string" value="1"/>

      <param name="Vis/MinInliers"            type="string" value="10"/>
      <param name="Vis/Iterations"            type="string" value="300"/>
      <param name="Vis/InlierDistance"        type="string" value="0.1"/>
      <param name="Vis/DepthAsMask"           type="string" value="false"/>

      <param name="Reg/Strategy"              type="string" value="2"/>

      <param name="Icp/MaxCorrespondenceDistance" type="string" value="0.15"/>
      <param name="Icp/PointToPlane"             type="string" value="false"/>
      <param name="Icp/Iterations"               type="string" value="30"/>
      <param name="Icp/MaxTranslation"           type="string" value="0.5"/>
      <param name="Icp/MaxRotation"              type="string" value="0.52"/>

      <!-- Grid map built from laser scan -->
      <param name="Grid/Sensor"               type="string" value="1"/>
      <param name="Grid/RangeMax"             type="string" value="10.0"/>

      <param name="Mem/RehearsalSimilarity"   type="string" value="0.30"/>
      <param name="Mem/STMSize"               type="string" value="50"/>
      <param name="Mem/NotLinkedNodesKept"    type="string" value="true"/>
      <param name="Mem/IncrementalMemory"     type="string" value="true"/>

      <param name="Optimizer/Strategy"        type="string" value="2"/>
      <param name="Optimizer/Robust"          type="string" value="true"/>
      <param name="Optimizer/Iterations"      type="string" value="100"/>

    </node>

    <node pkg="rtabmap_viz" type="rtabmap_viz" name="rtabmapviz" output="screen">
      <param name="subscribe_depth" type="bool"   value="true"/>
      <param name="subscribe_scan"  type="bool"   value="true"/>
      <param name="frame_id"        type="string" value="robot_footprint"/>

      <remap from="scan"            to="/scan"/>
      <remap from="rgb/image"       to="$(arg rgb_topic)"/>
      <remap from="depth/image"     to="$(arg depth_topic)"/>
      <remap from="rgb/camera_info" to="$(arg camera_info_topic)"/>
    </node>
  </group>
</launch>
